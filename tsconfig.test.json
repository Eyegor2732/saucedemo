{
  "extends": "./tsconfig.json",
    "compilerOptions": {
    "paths": {
      "@utils/*": ["./utils/*"],
      "@data/*": ["./data/*"],
      "@pageObjects/*": ["./pageObjects/*"],
      "@pages/*": ["./pageObjects/pages/*"],
      "@modals/*": ["./pageObjects/modals/*"],
    },
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "skipLibCheck": true,
    "isolatedModules": true,
    "noEmit": true
  },
  "include": [
    "tests",
    "pageObjects",
    "data",
    "utils",
    "api",
    "pages",
    "components", "thoughts/inventory.spec.ts",
  ]
}